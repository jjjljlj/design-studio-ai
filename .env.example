PORT=5173

# Text model routing: auto / openai / deepseek / qwen / demo
TEXT_PROVIDER=auto

# Image model routing: auto / openai / qwen / demo
IMAGE_PROVIDER=auto

# OpenAI: text + image
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_TEXT_MODEL=gpt-5.5
OPENAI_IMAGE_MODEL=gpt-image-2

# DeepSeek: cost-effective text generation for briefs, prompts, listings, scripts
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_TEXT_MODEL=deepseek-chat
DEEPSEEK_BASE_URL=https://api.deepseek.com

# Qwen / Alibaba DashScope: text and optional image generation
QWEN_API_KEY=your_dashscope_api_key_here
QWEN_TEXT_MODEL=qwen-plus
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_IMAGE_MODEL=wanx2.1-t2i-turbo
QWEN_IMAGE_SIZE=1024*1536
