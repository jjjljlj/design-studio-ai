PORT=5173

# Text model routing: auto / openai / deepseek / qwen / demo
TEXT_PROVIDER=auto

# Image model routing: auto / openai / qwen / demo
IMAGE_PROVIDER=auto

# OpenAI: text + image
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_TEXT_MODEL=gpt-5.5
OPENAI_IMAGE_MODEL=gpt-image-2

# DeepSeek: cost-effective text generation for briefs, prompts, listings, scripts
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_TEXT_MODEL=deepseek-chat
DEEPSEEK_BASE_URL=https://api.deepseek.com

# Qwen / Alibaba DashScope: text and optional image generation
QWEN_API_KEY=your_dashscope_api_key_here
QWEN_TEXT_MODEL=qwen-plus
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_IMAGE_MODEL=wanx2.1-t2i-turbo
QWEN_IMAGE_SIZE=1024*1440

# Virtual try-on / reference-image workflow, disabled until a paid provider is approved.
# tryon providers: disabled / aliyun-aitryon / fashn
TRYON_PROVIDER=disabled

# Alibaba Cloud Model Studio OutfitAnyone-Plus / aitryon-plus
# Requires DashScope access in the supported region and customer authorization for uploaded garment/model images.
ALIYUN_TRYON_API_KEY=your_aliyun_dashscope_key_here
ALIYUN_TRYON_MODEL=aitryon-plus
ALIYUN_TRYON_REGION=cn-beijing

# FASHN / fal virtual try-on
# Requires separate account balance and authorization for customer garment/model images.
FASHN_API_KEY=your_fashn_or_fal_key_here
FASHN_TRYON_MODEL=fashn-tryon-v1.5

# Temporary image storage for try-on inputs.
# Providers usually require HTTP/HTTPS image URLs, not local files.
TRYON_IMAGE_STORAGE=manual
TRYON_IMAGE_URL_TTL_MINUTES=60

# Optional admin page PIN for /admin.html
ADMIN_PIN=change_this_to_your_private_pin

# Optional persistent storage for projects, customer feedback, and Lina's library.
# Without these values, Render free services may lose saved records after restart/redeploy.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here
SUPABASE_TABLE=design_records
